#!/usr/bin/env bash
# Generated by `chefe install` — source it to set up the whole environment
# (HPC modules + pixi env), then run `python -m ...`.
# Regenerate with `chefe activate`; do not edit by hand.

# Module inits and conda activation scripts are not nounset-safe, so relax `set -u`
# while activating and restore it afterwards for callers that run under it.
case $- in *u*) _chefe_nounset=1; set +u;; *) _chefe_nounset=0;; esac

{% if modules %}
# HPC modules (guarded so it no-ops off a cluster).
{{ module_init }}
if command -v module >/dev/null 2>&1; then
  module purge
  module load {{ modules }}
fi

{% endif %}
# pixi env activation (env vars, PATH, activation scripts) — same as `chefe run`.
{{ hook }}

# `if` rather than `&&` so a false test cannot trip a caller running under `set -e`.
if [ "${_chefe_nounset}" = 1 ]; then set -u; fi
unset _chefe_nounset
