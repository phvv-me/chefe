# name: test_pixi_toml_snapshot[full]
  '''
  [workspace]
  name = "demo"
  version = "0.2.0"
  channels = ["conda-forge", "nvidia"]
  platforms = ["osx-arm64", "linux-64"]
  
  [system-requirements]
  cuda = "13.0"
  
  [activation.env]
  LOG_LEVEL = "info"
  
  [dependencies]
  python = ">=3.11"
  ripgrep = "*"
  rust = "*"
  nodejs = "*"
  
  [pypi-dependencies]
  ruff = ">=0.6"
  
  [pypi-dependencies.torch]
  version = ">=2.6"
  index = "https://download.pytorch.org/whl/cu124"
  
  [pypi-options]
  index-strategy = "unsafe-best-match"
  
  [target.linux.dependencies]
  cupy = ">=13"
  
  [feature.serving]
  platforms = ["linux-64"]
  
  [feature.serving.dependencies]
  python = "*"
  
  [feature.serving.pypi-dependencies]
  vllm = ">=0.6"
  
  [feature.serving.system-requirements]
  cuda = "12.0"
  
  [environments.serving]
  features = ["serving"]
  no-default-feature = true
  
  [tasks]
  build = "python -m demo.build"
  
  [tasks.serve]
  cmd = "python -m demo.server"
  depends-on = ["build"]
  
  '''
# ---
# name: test_pixi_toml_snapshot[minimal]
  '''
