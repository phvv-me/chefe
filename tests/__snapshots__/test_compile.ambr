# ---
# name: test_pixi_toml_snapshot[full]
  '''
  [workspace]
  name = "demo"
  version = "0.2.0"
  channels = ["conda-forge", "nvidia"]
  platforms = [{name = "osx-arm64-system", platform = "osx-arm64", cuda = "13.0"}, {name = "linux-64-system", platform = "linux-64", cuda = "13.0"}, {name = "linux-64-serving", platform = "linux-64", cuda = "12.0"}]
  
  [activation]
  scripts = ["dotenv.sh"]
  
  [activation.env]
  LOG_LEVEL = "info"
  
  [dependencies]
  python = ">=3.11"
  ripgrep = "*"
  nodejs = "*"
  rust = "*"
  zig = ">=0.14"
  c-compiler = "*"
  cxx-compiler = "*"
  
  [pypi-dependencies]
  ruff = ">=0.6"
  
  [pypi-dependencies.torch]
  version = ">=2.6"
  index = "https://download.pytorch.org/whl/cu124"
  
  [pypi-options]
  index-strategy = "unsafe-best-match"
  
  [target.linux.dependencies]
  cupy = ">=13"
  
  [feature.serving]
  platforms = ["linux-64-serving"]
  
  [feature.serving.dependencies]
  python = "*"
  
  [feature.serving.pypi-dependencies]
  vllm = ">=0.6"
  
  [feature.chefe-system]
  platforms = ["osx-arm64-system", "linux-64-system"]
  
  [environments.serving]
  features = ["serving"]
  no-default-feature = true
  
  [environments.default]
  features = ["chefe-system"]
  
  [tasks.build]
  cmd = "python -m demo.build"
  cwd = ".."
  
  [tasks.serve]
  cmd = "python -m demo.server"
  depends-on = ["build"]
  cwd = ".."
  
  '''
# ---
# name: test_pixi_toml_snapshot[minimal]
  '''
  [workspace]
  name = "tiny"
  version = "0.1.0"
  channels = ["conda-forge"]
  platforms = ["linux-64"]
  
  [activation]
  scripts = ["dotenv.sh"]
  
  [dependencies]
  python = ">=3.11"
  
  '''
